            "content": "package main\nimport \"fmt\"\n\nfunc quantosCasais(animais []int) int {\n\tres := 0\n\tarray := animais\n\tfor i := range array {\n\t\tif array[i] == 0 {\n\t\t\tcontinue\n\t\t}\n\t\tfor j:= range array {\n\t\t\tif array[j] == -(array[i]) {\n\t\t\t\tres++\n\t\t\t\tarray[i] = 0\n\t\t\t\tarray[j] = 0\n\t\t\t\tbreak\n\t\t\t}\n\t\t}\n\t}\n\n\treturn res\n}\n\nfunc main() {\n\tvar n int\n\n\tfmt.Scan(&n)\n\n\tanimais := make([]int, n)\n\n\tfor i:= range animais {\n\t\tfmt.Scan(&animais[i])\n\t}\n\n\tfmt.Println(quantosCasais(animais))\n\n}\n",
