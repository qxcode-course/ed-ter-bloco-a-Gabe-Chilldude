        {
            "label": "2026-04-08_20-14-47",
            "content": "package main\n\nimport (\n\t\"fmt\"\n\t\"math/rand\"\n)\n\nfunc randInt(min, max int) int {\n\treturn min + rand.Intn(max-min+1)\n}\n\nfunc troncao(pen* Pen, dist float64) {\n\tpen.Walk(dist)\n\tarvore(pen, dist)\n}\nfunc arvore(pen* Pen, dist float64) {\n\tif(dist<2) {\n\t\treturn\n\t}\n\n\tangle := 45.0\n\n\tpen.Right(angle)\n\tpen.Walk(dist)\n\n\tarvore(pen, dist-10)\n\n\tpen.Up()\n\tpen.Walk(-dist) // anda pra tras\n\tpen.Left(angle*2) // muda angulo\n\tpen.Down()\n\n\tpen.Walk(dist) // faz galho\n\n\tarvore(pen, dist-10)\n\n\tpen.Walk(-dist)\n\n\n\tpen.Right(angle)\n}\n\nfunc quadrado(pen* Pen, side float64) {\n\tif(side<250) {\n\t\treturn\n\t}\n\n\tpen.DrawRect(side, side)\n\tpen.Up()\n\tpen.Walk(side/4)\n\tpen.Left(90)\n\tpen.Walk(side/4)\n\tpen.Right(90)\n\tpen.Down()\n\n\tquadrado(pen, side/2)\n\n\tpen.Up()\n\t\tpen.Right(180)\n\t\tpen.Walk(side)\n\t\tpen.Right(180)\n\tpen.Down()\n\n\tquadrado(pen, side/2)\n\n\tpen.Up()\n\t\tpen.Right(90)\n\t\tpen.Walk(side)\n\t\tpen.Left(90)\n\tpen.Down()\n\n\tquadrado(pen, side/2)\n\n\tquadrado(pen, side/2)\n\n\tpen.Up()\n\t\tpen.Walk(side)\n\tpen.Down()\n\n\tquadrado(pen, side/2)\n\n\tpen.Up()\n\t\tpen.Right(180)\n\t\tpen.Walk(side/4)\n\t\tpen.Right(90)\n\t\tpen.Walk(side*0.75)\n\t\tpen.Right(90)\n\tpen.Down()\n}\n\nfunc main() {\n\tpen := NewPen(2000, 2000)   // cria um canvas de 500 de largura por 500 de altura\n\tpen.Up()\n\tpen.Goto(500, 500)\n\tpen.Down()\n\tpen.Left(90)\n\tquadrado(pen, 500)\n\tpen.SavePNG(\"tree.png\")\n\tfmt.Println(\"PNG file created successfully.\")\n}\n",
            "lines": "100"
        }
